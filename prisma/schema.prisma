generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ── Sessions (auth via cookie) ──
model Session {
  sid       String   @id
  data      String // JSON serializado
  expiresAt DateTime

  @@map("sessions")
}

// ── Scripts (arquivos executáveis gerenciados pela UI) ──
model Script {
  id        String   @id @default(uuid())
  nome      String
  descricao String?
  tipo      String // SHELL | NODEJS | PYTHON
  arquivo   String   @unique @map("arquivo") // nome do arquivo em scripts/user/
  conteudo  String   @default("") // conteúdo salvo no banco (espelho do arquivo)
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tarefas   Tarefa[]
  execucoes Execucao[]

  @@map("scripts")
}

// ── Tarefas agendadas ──
model Tarefa {
  id               String   @id @default(uuid())
  nome             String
  descricao        String?
  comandoOuPayload String?  @map("comando_ou_payload")
  webhookUrl       String?  @map("webhook_url")
  ativo            Boolean  @default(true)
  diasSemana       String   @default("[]") @map("dias_semana") // JSON: number[] (0=dom, 6=sab)
  horarios         String   @default("[]") // JSON: string[] ("HH:MM")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  scriptId String? @map("script_id")
  script   Script? @relation(fields: [scriptId], references: [id], onDelete: SetNull)

  execucoes Execucao[]

  @@map("tarefas")
}

// ── Log de execuções ──
model Execucao {
  id          String   @id @default(uuid())
  status      String // SUCESSO | FALHA | EM_ANDAMENTO
  saida       String? // JSON output
  duracao     Int? // ms
  executadoEm DateTime @default(now()) @map("executado_em")

  tarefaId String? @map("tarefa_id")
  tarefa   Tarefa? @relation(fields: [tarefaId], references: [id], onDelete: Cascade)

  scriptId String? @map("script_id")
  script   Script? @relation(fields: [scriptId], references: [id], onDelete: SetNull)

  @@map("execucoes")
}
