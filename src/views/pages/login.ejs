<!DOCTYPE html>
<html lang="pt-BR">
<script>
  // Pre-render script to prevent theme flashing and detect system preference
  (function() {
    const savedTheme = localStorage.getItem('theme');
    if (savedTheme) {
      document.documentElement.setAttribute('data-theme', savedTheme);
    } else {
      const systemTheme = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'business' : 'corporate';
      document.documentElement.setAttribute('data-theme', systemTheme);
    }
  })();
</script>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login — Fatia Rápida</title>
  <link href="https://cdn.jsdelivr.net/npm/daisyui@4.12.14/dist/full.min.css" rel="stylesheet" type="text/css" />
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://cdn.jsdelivr.net/npm/lucide@latest/dist/umd/lucide.min.js"></script>
</head>
<body class="min-h-screen bg-base-100 flex items-center justify-center p-4">
  <!-- Theme Toggle Floating Button -->
  <div class="fixed top-4 right-4">
    <button id="theme-toggle" class="btn btn-ghost btn-circle btn-sm shadow-sm bg-base-200/50 backdrop-blur-sm" title="Alternar tema">
      <i data-lucide="sun" id="theme-sun" class="w-4 h-4 hidden"></i>
      <i data-lucide="moon" id="theme-moon" class="w-4 h-4 hidden"></i>
    </button>
  </div>
  <div class="w-full max-w-sm">
    <div class="card bg-base-200 shadow-2xl">
      <div class="card-body gap-4">

        <div class="text-center">
          <div class="flex justify-center mb-3"><i data-lucide="pizza" class="w-12 h-12 text-primary"></i></div>
          <h1 class="text-2xl font-bold">Fatia Rápida</h1>
          <p class="text-base-content/50 text-sm mt-1">Automação de tarefas</p>
        </div>

        <% if (typeof error !== 'undefined' && error) { %>
          <div role="alert" class="alert alert-error">
            <svg xmlns="http://www.w3.org/2000/svg" class="stroke-current shrink-0 h-5 w-5" fill="none" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <span><%= error %></span>
          </div>
        <% } %>

        <form method="POST" action="/login" class="flex flex-col gap-3">
          <div class="form-control">
            <label class="label" for="username">
              <span class="label-text">Usuário</span>
            </label>
            <input
              type="text"
              id="username"
              name="username"
              placeholder="admin"
              value="<%= typeof username !== 'undefined' ? username : '' %>"
              required
              autofocus
              autocomplete="username"
              class="input input-bordered w-full"
            >
          </div>

          <div class="form-control">
            <label class="label" for="password">
              <span class="label-text">Senha</span>
            </label>
            <input
              type="password"
              id="password"
              name="password"
              placeholder="••••••••"
              required
              class="input input-bordered w-full"
            >
          </div>

          <button type="submit" class="btn btn-primary w-full mt-2">
            <i data-lucide="log-in" class="w-4 h-4"></i> Entrar
          </button>
        </form>

        <div class="divider my-1"></div>

        <a href="/about" class="btn btn-ghost btn-sm w-full gap-2 text-base-content/50 hover:text-base-content">
          <i data-lucide="info" class="w-4 h-4"></i>
          <span class="text-xs">Sobre o projeto</span>
        </a>

      </div>
    </div>
  </div>
  <script>
    document.addEventListener('DOMContentLoaded', function() { 
      if (typeof lucide !== 'undefined') lucide.createIcons(); 

      // Theme toggle logic
      (function() {
        const sun = document.getElementById('theme-sun');
        const moon = document.getElementById('theme-moon');
        const toggle = document.getElementById('theme-toggle');

        function updateIcons(theme) {
          if (theme === 'business') {
            sun.classList.remove('hidden');
            moon.classList.add('hidden');
          } else {
            sun.classList.add('hidden');
            moon.classList.remove('hidden');
          }
        }

        const currentTheme = document.documentElement.getAttribute('data-theme') || 'corporate';
        updateIcons(currentTheme);

        toggle.addEventListener('click', () => {
          const isDark = document.documentElement.getAttribute('data-theme') === 'business';
          const newTheme = isDark ? 'corporate' : 'business';

          document.documentElement.setAttribute('data-theme', newTheme);
          localStorage.setItem('theme', newTheme);
          updateIcons(newTheme);

          if (window.lucide) lucide.createIcons();
        });
      })();
    });
  </script>
</body>
</html>
