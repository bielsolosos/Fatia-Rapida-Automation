<%- include('../layouts/header', {
  title: typeof statusCode !== 'undefined' ? 'Erro ' + statusCode : 'Erro',
  isAuthenticated: typeof isAuthenticated !== 'undefined' ? isAuthenticated : false,
  currentPage: ''
}) %>

<div class="hero min-h-[60vh]">
  <div class="hero-content text-center">
    <div class="max-w-md">
      <h1 class="text-8xl font-bold text-error"><%= typeof statusCode !== 'undefined' ? statusCode : '?' %></h1>
      <p class="py-6 text-base-content/70"><%= typeof message !== 'undefined' ? message : 'Algo deu errado.' %></p>
      <a href="/" class="btn btn-primary">Voltar ao início</a>
    </div>
  </div>
</div>

<%- include('../layouts/footer') %>
