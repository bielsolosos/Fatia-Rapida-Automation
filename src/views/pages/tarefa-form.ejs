<%
  const isEdit  = typeof tarefa  !== 'undefined';
  const isClone = typeof prefill !== 'undefined';
  const src = isEdit ? tarefa : (isClone ? prefill : null);
  const pageTitle = isEdit ? 'Editar Tarefa' : (isClone ? 'Clonar Tarefa' : 'Nova Tarefa');
%>
<%- include('../layouts/header', {
  title: pageTitle,
  isAuthenticated: true,
  currentPage: 'tarefas'
}) %>

<div class="max-w-2xl mx-auto space-y-6">
  <h2 class="text-2xl font-bold flex items-center gap-2">
    <% if (isEdit) { %><i data-lucide="pencil" class="w-6 h-6"></i> Editar Tarefa
    <% } else if (isClone) { %><i data-lucide="copy" class="w-6 h-6"></i> Clonar Tarefa
    <% } else { %><i data-lucide="plus" class="w-6 h-6"></i> Nova Tarefa<% } %>
  </h2>

  <% if (typeof errors !== 'undefined' && errors) { %>
    <div role="alert" class="alert alert-error">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 shrink-0 stroke-current" fill="none" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
      <div>
        <% if (Array.isArray(errors)) { %>
          <ul class="list-disc list-inside">
            <% errors.forEach(function(e) { %><li><%= e.message %></li><% }); %>
          </ul>
        <% } else { %>
          <%= errors %>
        <% } %>
      </div>
    </div>
  <% } %>

  <form
    method="POST"
    action="<%= isEdit ? '/tarefas/' + tarefa.id : '/tarefas' %>"
    class="card bg-base-200 shadow"
  >
    <div class="card-body space-y-4">
      <% if (isEdit) { %>
        <input type="hidden" name="_method" value="PUT">
      <% } %>

      <div class="form-control">
        <label class="label" for="nome"><span class="label-text">Nome *</span></label>
        <input
          type="text"
          id="nome"
          name="nome"
          class="input input-bordered w-full"
          value="<%= src ? src.nome : (typeof values !== 'undefined' && values.nome ? values.nome : '') %>"
          placeholder="Ex: Ponto matutino"
          required
          maxlength="100"
        >
      </div>

      <div class="form-control">
        <label class="label" for="descricao"><span class="label-text">Descrição</span></label>
        <textarea
          id="descricao"
          name="descricao"
          class="textarea textarea-bordered w-full"
          placeholder="Descrição opcional..."
          maxlength="500"
        ><%= src && src.descricao ? src.descricao : (typeof values !== 'undefined' && values.descricao ? values.descricao : '') %></textarea>
      </div>

      <div class="form-control">
        <label class="label" for="webhookUrl"><span class="label-text">Webhook URL (Discord)</span></label>
        <input
          type="url"
          id="webhookUrl"
          name="webhookUrl"
          class="input input-bordered w-full"
          value="<%= src && src.webhookUrl ? src.webhookUrl : (typeof values !== 'undefined' && values.webhookUrl ? values.webhookUrl : '') %>"
          placeholder="https://discord.com/api/webhooks/..."
        >
      </div>

      <% if (typeof scripts !== 'undefined' && scripts && scripts.length > 0) { %>
      <div class="form-control">
        <label class="label" for="scriptId">
          <span class="label-text">Script vinculado</span>
          <span class="label-text-alt text-base-content/50">Substitui o campo Comando quando selecionado</span>
        </label>
        <select id="scriptId" name="scriptId" class="select select-bordered w-full">
          <option value="">Nenhum (usar comando abaixo)</option>
          <% scripts.forEach(function(s) {
            const selected = (src && src.scriptId === s.id) || (typeof values !== 'undefined' && values.scriptId === s.id);
          %>
          <option value="<%= s.id %>" <%= selected ? 'selected' : '' %>><%= s.nome %> (<%= s.tipo %>)</option>
          <% }); %>
        </select>
      </div>
      <% } %>

      <div id="comando-section" class="form-control">
        <label class="label" for="comandoOuPayload"><span class="label-text">Comando / Payload</span></label>
        <textarea
          id="comandoOuPayload"
          name="comandoOuPayload"
          class="textarea textarea-bordered w-full font-mono text-sm"
          placeholder="Payload JSON ou comando..."
          maxlength="2000"
        ><%= src && src.comandoOuPayload ? src.comandoOuPayload : (typeof values !== 'undefined' && values.comandoOuPayload ? values.comandoOuPayload : '') %></textarea>
      </div>

      <div class="divider"><i data-lucide="calendar" class="w-4 h-4"></i> Agendamento</div>

      <div id="agendamentos-container">
        <%- include('../partials/agendamento-fields', { tarefa: src }) %>
      </div>

      <div class="divider"></div>

      <div class="flex gap-3 justify-end">
        <a href="/tarefas" class="btn btn-ghost">Cancelar</a>
        <button type="submit" class="btn btn-primary">
          <% if (isEdit) { %><i data-lucide="save" class="w-4 h-4"></i> Salvar Alterações
          <% } else if (isClone) { %><i data-lucide="copy" class="w-4 h-4"></i> Clonar Tarefa
          <% } else { %><i data-lucide="plus" class="w-4 h-4"></i> Criar Tarefa<% } %>
        </button>
      </div>
    </div>
  </form>
</div>

<%- include('../layouts/footer') %>
