<%- include('../layouts/header', {
  title: 'Scripts',
  isAuthenticated: true,
  currentPage: 'scripts'
}) %>

<div class="space-y-6">
  <div class="flex items-center justify-between">
    <h2 class="text-2xl font-bold flex items-center gap-2">
      <i data-lucide="code-2" class="w-6 h-6"></i> Scripts
    </h2>
    <a href="/scripts/novo" class="btn btn-primary btn-sm gap-2">
      <i data-lucide="plus" class="w-4 h-4"></i> Novo Script
    </a>
  </div>

  <!-- Diretório dos scripts -->
  <div class="alert bg-base-200 border border-base-content/10 py-3 gap-3">
    <i data-lucide="folder-open" class="w-4 h-4 shrink-0 text-base-content/50"></i>
    <div class="min-w-0 flex-1">
      <p class="text-xs font-semibold text-base-content/60 mb-0.5">Diretório dos scripts</p>
      <code class="text-sm font-mono break-all"><%= scriptsDir %></code>
    </div>
    <div class="text-xs text-base-content/40 hidden sm:block shrink-0">
      <p>Use <code class="bg-base-content/10 px-1 rounded">npm install &lt;pacote&gt;</code> neste diretório</p>
      <p>para ter libs disponíveis nos seus scripts Node.js.</p>
    </div>
  </div>

  <% if (!scripts || scripts.length === 0) { %>
    <div class="hero min-h-32 bg-base-200 rounded-box">
      <div class="hero-content text-center">
        <div>
          <i data-lucide="file-code-2" class="w-12 h-12 mx-auto opacity-30 mb-3"></i>
          <p class="text-base-content/60">Nenhum script criado ainda.</p>
          <a href="/scripts/novo" class="btn btn-primary btn-sm mt-3">Criar primeiro script</a>
        </div>
      </div>
    </div>
  <% } else { %>
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3" id="scripts-grid">
      <% scripts.forEach(function(script) { %>
        <%- include('../partials/script-card', { script }) %>
      <% }); %>
    </div>
  <% } %>
</div>

<%- include('../layouts/footer') %>
