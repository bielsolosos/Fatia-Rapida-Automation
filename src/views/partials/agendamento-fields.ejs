<div class="agendamento-fields border border-base-300 rounded-lg p-4 space-y-4">

  <div class="form-control">
    <label class="label"><span class="label-text">Dias da semana</span></label>
    <div class="dias-grid flex flex-wrap gap-2">
      <% const diasNomes = ['Dom','Seg','Ter','Qua','Qui','Sex','Sáb']; %>
      <% diasNomes.forEach(function(dia, i) { %>
        <%
          const diasParsed = tarefa && tarefa.diasSemana
            ? JSON.parse(tarefa.diasSemana)
            : [];
          const checked = diasParsed.includes(i);
        %>
        <label class="dia-check flex items-center gap-1 border border-base-300 rounded px-2 py-1 text-sm<%= checked ? ' selected' : '' %>">
          <input
            type="checkbox"
            class="hidden"
            name="diasSemana"
            value="<%= i %>"
            <%= checked ? 'checked' : '' %>
          >
          <%= dia %>
        </label>
      <% }); %>
    </div>
  </div>

  <div class="form-control">
    <label class="label"><span class="label-text">Horários</span></label>
    <div class="space-y-2 horarios-list">
      <%
        const horariosParsed = tarefa && tarefa.horarios
          ? JSON.parse(tarefa.horarios)
          : [''];
      %>
      <% horariosParsed.forEach(function(h, hi) { %>
        <div class="flex items-center gap-2 horario-input-group">
          <input
            type="time"
            name="horarios"
            value="<%= h %>"
            class="input input-bordered input-sm w-36"
            required
          >
          <% if (hi > 0) { %>
            <button type="button" class="btn btn-xs btn-square btn-error btn-outline remove-horario"><i data-lucide="x" class="w-3 h-3"></i></button>
          <% } %>
        </div>
      <% }); %>
    </div>
    <button
      type="button"
      class="btn btn-outline btn-xs mt-2 w-fit add-horario"
    >
      <i data-lucide="plus" class="w-3 h-3"></i> Horário
    </button>
  </div>

</div>
