<div class="card bg-base-200 shadow compact" id="task-<%= tarefa.id %>">
  <div class="card-body">
    <div class="flex items-start justify-between gap-2">
      <h4 class="card-title text-base"><%= tarefa.nome %></h4>
      <span class="badge badge-sm <%= tarefa.ativo ? 'badge-success' : 'badge-ghost' %> shrink-0">
        <%= tarefa.ativo ? 'Ativo' : 'Inativo' %>
      </span>
    </div>

    <% if (tarefa.descricao) { %>
      <p class="text-sm text-base-content/70"><%= tarefa.descricao %></p>
    <% } %>

    <% if (tarefa.webhookUrl) { %>
      <p class="text-xs text-base-content/50 flex items-center gap-1"><i data-lucide="link" class="w-3 h-3"></i> Webhook configurado</p>
    <% } %>

    <% if (tarefa.agendamentos && tarefa.agendamentos.length > 0) { %>
      <details class="text-sm">
        <summary class="cursor-pointer text-base-content/60"><i data-lucide="calendar" class="w-4 h-4 inline align-text-bottom"></i> <%= tarefa.agendamentos.length %> agendamento(s)</summary>
        <ul class="mt-2 space-y-1 pl-2">
          <% tarefa.agendamentos.forEach(function(ag) { %>
            <% const dias = JSON.parse(ag.diasSemana); %>
            <% const horarios = JSON.parse(ag.horarios); %>
            <% const nomes = ['Dom','Seg','Ter','Qua','Qui','Sex','Sáb']; %>
            <li class="text-xs text-base-content/70">
              <strong><%= dias.map(function(d) { return nomes[d]; }).join(', ') %></strong>
              às <%= horarios.join(', ') %>
              <% if (!ag.ativo) { %><em class="text-warning">(pausado)</em><% } %>
            </li>
          <% }); %>
        </ul>
      </details>
    <% } %>

    <div class="card-actions justify-end mt-2">
      <button
        class="btn btn-sm btn-outline <%= tarefa.ativo ? '' : 'btn-success' %>"
        hx-patch="/tarefas/<%= tarefa.id %>/toggle"
        hx-target="#task-<%= tarefa.id %>"
        hx-swap="outerHTML"
      >
        <%= tarefa.ativo ? 'Pausar' : 'Ativar' %>
      </button>

      <a href="/tarefas/<%= tarefa.id %>/editar" class="btn btn-sm btn-outline">
        <i data-lucide="pencil" class="w-4 h-4"></i> Editar
      </a>

      <button
        class="btn btn-sm btn-square btn-ghost text-error"
        hx-delete="/tarefas/<%= tarefa.id %>"
        hx-target="#task-<%= tarefa.id %>"
        hx-swap="outerHTML swap:300ms"
        hx-confirm="Tem certeza que deseja excluir esta tarefa?"
        title="Excluir"
      >
        <i data-lucide="trash-2" class="w-4 h-4"></i>
      </button>
    </div>
  </div>
</div>
