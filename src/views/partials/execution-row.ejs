<tr id="exec-<%= exec.id %>">
  <td class="text-sm">
    <%= new Date(exec.executadoEm).toLocaleString('pt-BR', { timeZone: 'America/Sao_Paulo' }) %>
  </td>
  <td>
    <span class="badge badge-sm <%= exec.status === 'SUCESSO' ? 'badge-success' : exec.status === 'FALHA' ? 'badge-error' : 'badge-warning' %>">
      <%= exec.status %>
    </span>
  </td>
  <td class="text-sm">
    <% if (exec.tarefa) { %>
      <%= exec.tarefa.nome %>
    <% } else if (exec.script) { %>
      <span class="opacity-60">Script:</span> <%= exec.script.nome %>
    <% } else { %>
      <span class="opacity-40">(avulso)</span>
    <% } %>
  </td>
  <td class="text-sm"><%= exec.duracao ? exec.duracao + 'ms' : '—' %></td>
  <td>
    <% if (exec.saida) { %>
      <button
        class="btn btn-xs btn-ghost"
        hx-get="/execucoes/<%= exec.id %>/detalhes"
        hx-target="#exec-detail-modal"
        hx-swap="innerHTML"
      >
        <i data-lucide="eye" class="w-3 h-3"></i> Ver
      </button>
    <% } else { %>
      <span class="text-base-content/30">—</span>
    <% } %>
  </td>
</tr>
