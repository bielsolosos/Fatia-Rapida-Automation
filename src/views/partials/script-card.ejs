<div class="card bg-base-200 shadow hover:shadow-md transition-shadow" id="script-<%= script.id %>">
  <div class="card-body p-4 space-y-3">
    <!-- Header -->
    <div class="flex items-start justify-between gap-2">
      <div class="flex-1 min-w-0">
        <h3 class="font-semibold text-sm truncate"><%= script.nome %></h3>
        <% if (script.descricao) { %>
          <p class="text-xs text-base-content/60 truncate mt-0.5"><%= script.descricao %></p>
        <% } %>
        <!-- Filename real para referenciar de outros scripts -->
        <p class="text-xs text-base-content/40 font-mono truncate mt-1" title="<%= script.arquivo %>">
          <i data-lucide="file-code" class="w-3 h-3 inline -mt-0.5"></i>
          <%= script.arquivo %>
        </p>
      </div>
      <% const tipoClasses = { SHELL: 'badge-neutral', NODEJS: 'badge-success', PYTHON: 'badge-info' }; %>
      <span class="badge badge-sm <%= tipoClasses[script.tipo] || 'badge-neutral' %>">
        <%= script.tipo %>
      </span>
    </div>

    <!-- Stats -->
    <div class="flex gap-3 text-xs text-base-content/50">
      <span class="flex items-center gap-1">
        <i data-lucide="clipboard-list" class="w-3 h-3"></i>
        <%= script._count ? script._count.tarefas : 0 %> tarefa(s)
      </span>
      <span class="flex items-center gap-1">
        <i data-lucide="play" class="w-3 h-3"></i>
        <%= script._count ? script._count.execucoes : 0 %> execução(ões)
      </span>
    </div>

    <!-- Output manual -->
    <div id="output-<%= script.id %>"></div>

    <!-- Actions -->
    <div class="flex gap-2 flex-wrap pt-1 border-t border-base-300">
      <button
        class="btn btn-xs btn-success gap-1"
        hx-post="/scripts/<%= script.id %>/executar"
        hx-target="#output-<%= script.id %>"
        hx-swap="innerHTML"
        hx-indicator="#output-<%= script.id %>"
      >
        <i data-lucide="play" class="w-3 h-3"></i> Executar
      </button>
      <a href="/scripts/<%= script.id %>/editar" class="btn btn-xs btn-ghost gap-1">
        <i data-lucide="pencil" class="w-3 h-3"></i> Editar
      </a>
      <button
        class="btn btn-xs btn-error btn-outline gap-1 ml-auto"
        hx-delete="/scripts/<%= script.id %>"
        hx-target="#script-<%= script.id %>"
        hx-swap="outerHTML"
        hx-confirm="Tem certeza? O arquivo do script também será removido."
      >
        <i data-lucide="trash-2" class="w-3 h-3"></i>
      </button>
    </div>
  </div>
</div>
