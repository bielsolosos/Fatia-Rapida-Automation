<div class="flex flex-col h-full p-4 w-72 bg-base-200 text-base-content border-r border-base-300">
  <!-- Logo -->
  <div class="px-2 mb-8 mt-4">
    <a href="/" class="flex items-center gap-2 text-2xl font-black tracking-tight hover:opacity-80 transition-opacity">
      <div class="bg-primary text-primary-content p-1.5 rounded-lg">
        <i data-lucide="pizza" class="w-6 h-6"></i>
      </div>
      <span>Fatia <span class="text-primary">Rápida</span></span>
    </a>
  </div>

  <!-- Menu -->
  <ul class="menu menu-md flex-1 gap-1 px-0">
    <li class="menu-title opacity-50 text-xs font-bold uppercase tracking-widest mt-4 mb-2 px-2">Navegação</li>
    <li>
      <a href="/" class="<%= (typeof currentPage !== 'undefined' && currentPage === 'dashboard') ? 'active' : '' %>">
        <i data-lucide="layout-dashboard" class="w-5 h-5"></i> Dashboard
      </a>
    </li>
    <li>
      <a href="/tarefas" class="<%= (typeof currentPage !== 'undefined' && currentPage === 'tarefas') ? 'active' : '' %>">
        <i data-lucide="clipboard-list" class="w-5 h-5"></i> Tarefas
      </a>
    </li>
    <li>
      <a href="/scripts" class="<%= (typeof currentPage !== 'undefined' && currentPage === 'scripts') ? 'active' : '' %>">
        <i data-lucide="code-2" class="w-5 h-5"></i> Scripts
      </a>
    </li>
    <li>
      <a href="/execucoes" class="<%= (typeof currentPage !== 'undefined' && currentPage === 'execucoes') ? 'active' : '' %>">
        <i data-lucide="scroll-text" class="w-5 h-5"></i> Execuções
      </a>
    </li>

    <li class="menu-title opacity-50 text-xs font-bold uppercase tracking-widest mt-8 mb-2 px-2">Configurações</li>
    <li>
      <a href="/about" class="<%= (typeof currentPage !== 'undefined' && currentPage === 'about') ? 'active' : '' %>">
        <i data-lucide="info" class="w-5 h-5"></i> Sobre
      </a>
    </li>
  </ul>

  <!-- Bottom actions -->
  <div class="pt-4 mt-4 border-t border-base-300 flex flex-col gap-2">
    <!-- Theme Toggle -->
    <button id="theme-toggle-side" class="btn btn-ghost justify-start gap-3 w-full font-medium" title="Alternar tema">
      <span class="flex items-center gap-3" id="theme-side-content">
        <i data-lucide="sun" id="theme-sun-side" class="w-5 h-5 hidden"></i>
        <i data-lucide="moon" id="theme-moon-side" class="w-5 h-5 hidden"></i>
        <span id="theme-text-side">Tema</span>
      </span>
    </button>

    <form method="POST" action="/logout" class="w-full">
      <button type="submit" class="btn btn-ghost text-error justify-start gap-3 w-full font-medium">
        <i data-lucide="log-out" class="w-5 h-5"></i> Sair
      </button>
    </form>
  </div>
</div>

<script>
  (function() {
    const sun = document.getElementById('theme-sun-side');
    const moon = document.getElementById('theme-moon-side');
    const text = document.getElementById('theme-text-side');
    const toggle = document.getElementById('theme-toggle-side');

    if (!toggle) return;

    function updateIcons(theme) {
      if (theme === 'business') {
        sun.classList.remove('hidden');
        moon.classList.add('hidden');
        text.textContent = 'Modo Escuro';
      } else {
        sun.classList.add('hidden');
        moon.classList.remove('hidden');
        text.textContent = 'Modo Claro';
      }
      if (window.lucide) lucide.createIcons();
    }

    const currentTheme = document.documentElement.getAttribute('data-theme') || 'corporate';
    updateIcons(currentTheme);

    toggle.addEventListener('click', () => {
      const isDark = document.documentElement.getAttribute('data-theme') === 'business';
      const newTheme = isDark ? 'corporate' : 'business';

      document.documentElement.setAttribute('data-theme', newTheme);
      localStorage.setItem('theme', newTheme);
      updateIcons(newTheme);
    });
  })();
</script>
