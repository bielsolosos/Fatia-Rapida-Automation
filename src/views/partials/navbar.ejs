<div class="navbar bg-base-200 shadow-lg px-4 sticky top-0 z-40">
  <div class="navbar-start">
    <a href="/" class="btn btn-ghost text-xl font-bold gap-2"
      ><i data-lucide="pizza" class="w-5 h-5"></i>
      <span class="hidden sm:inline">Fatia Rápida</span></a
    >
  </div>

  <div class="navbar-center hidden lg:flex">
    <ul class="menu menu-horizontal px-1 gap-1">
      <li>
        <a
          href="/"
          class="<% if (typeof currentPage !== 'undefined' && currentPage === 'dashboard') { %>active<% } %>"
          ><i data-lucide="layout-dashboard" class="w-4 h-4"></i> Dashboard</a
        >
      </li>
      <li>
        <a
          href="/tarefas"
          class="<% if (typeof currentPage !== 'undefined' && currentPage === 'tarefas') { %>active<% } %>"
          ><i data-lucide="clipboard-list" class="w-4 h-4"></i> Tarefas</a
        >
      </li>
      <li>
        <a
          href="/scripts"
          class="<% if (typeof currentPage !== 'undefined' && currentPage === 'scripts') { %>active<% } %>"
          ><i data-lucide="code-2" class="w-4 h-4"></i> Scripts</a
        >
      </li>
      <li>
        <a
          href="/execucoes"
          class="<% if (typeof currentPage !== 'undefined' && currentPage === 'execucoes') { %>active<% } %>"
          ><i data-lucide="scroll-text" class="w-4 h-4"></i> Execuções</a
        >
      </li>
    </ul>
  </div>

  <div class="navbar-end gap-2">
    <!-- Theme Toggle -->
    <button id="theme-toggle" class="btn btn-ghost btn-circle btn-sm" title="Alternar tema">
      <i data-lucide="sun" id="theme-sun" class="w-4 h-4 hidden"></i>
      <i data-lucide="moon" id="theme-moon" class="w-4 h-4 hidden"></i>
    </button>

    <a href="/about" class="btn btn-ghost btn-sm" title="Sobre o projeto">
      <i data-lucide="info" class="w-4 h-4"></i>
    </a>
    <form method="POST" action="/logout">
      <button type="submit" class="btn btn-sm btn-ghost">
        <i data-lucide="log-out" class="w-4 h-4"></i> Sair
      </button>
    </form>

    <script>
      document.addEventListener('DOMContentLoaded', function() {
        const sun = document.getElementById('theme-sun');
        const moon = document.getElementById('theme-moon');
        const toggle = document.getElementById('theme-toggle');

        function updateIcons(theme) {
          if (theme === 'business') {
            // Se o tema é escuro, mostra o sol para mudar para o claro
            sun.classList.remove('hidden');
            moon.classList.add('hidden');
          } else {
            // Se o tema é claro, mostra a lua para mudar para o escuro
            sun.classList.add('hidden');
            moon.classList.remove('hidden');
          }
          if (window.lucide) lucide.createIcons();
        }

        // Pega o tema real aplicado no momento (seja do localStorage ou do sistema)
        const currentTheme = document.documentElement.getAttribute('data-theme') || 'corporate';
        updateIcons(currentTheme);

        toggle.addEventListener('click', () => {
          const isDark = document.documentElement.getAttribute('data-theme') === 'business';
          const newTheme = isDark ? 'corporate' : 'business';

          document.documentElement.setAttribute('data-theme', newTheme);
          localStorage.setItem('theme', newTheme);
          updateIcons(newTheme);
        });
      });
    </script>
    <!-- Mobile dropdown -->
    <div class="dropdown dropdown-end lg:hidden">
      <div tabindex="0" role="button" class="btn btn-ghost btn-sm">
        <i data-lucide="menu" class="w-5 h-5"></i>
      </div>
      <ul
        tabindex="0"
        class="dropdown-content menu menu-sm bg-base-100 rounded-box z-[1] mt-3 w-52 p-2 shadow"
      >
        <li>
          <a href="/"
            ><i data-lucide="layout-dashboard" class="w-4 h-4"></i> Dashboard</a
          >
        </li>
        <li>
          <a href="/tarefas"
            ><i data-lucide="clipboard-list" class="w-4 h-4"></i> Tarefas</a
          >
        </li>
        <li>
          <a href="/scripts"
            ><i data-lucide="code-2" class="w-4 h-4"></i> Scripts</a
          >
        </li>
        <li>
          <a href="/execucoes"
            ><i data-lucide="scroll-text" class="w-4 h-4"></i> Execuções</a
          >
        </li>
        <li>
          <a href="/about"
            ><i data-lucide="info" class="w-4 h-4"></i> Sobre o projeto</a
          >
        </li>
        <li class="mt-1 border-t border-base-300 pt-1">
          <form method="POST" action="/logout">
            <button type="submit" class="w-full text-left">Sair</button>
          </form>
        </li>
      </ul>
    </div>
  </div>
</div>
