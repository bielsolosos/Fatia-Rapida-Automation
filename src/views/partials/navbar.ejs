<div class="navbar bg-base-200 shadow-lg px-4 sticky top-0 z-40">
  <div class="navbar-start">
    <a href="/" class="btn btn-ghost text-xl font-bold gap-2"
      ><i data-lucide="pizza" class="w-5 h-5"></i>
      <span class="hidden sm:inline">Fatia Rápida</span></a
    >
  </div>

  <div class="navbar-center hidden lg:flex">
    <ul class="menu menu-horizontal px-1 gap-1">
      <li>
        <a
          href="/"
          class="<% if (typeof currentPage !== 'undefined' && currentPage === 'dashboard') { %>active<% } %>"
          ><i data-lucide="layout-dashboard" class="w-4 h-4"></i> Dashboard</a
        >
      </li>
      <li>
        <a
          href="/tarefas"
          class="<% if (typeof currentPage !== 'undefined' && currentPage === 'tarefas') { %>active<% } %>"
          ><i data-lucide="clipboard-list" class="w-4 h-4"></i> Tarefas</a
        >
      </li>
      <li>
        <a
          href="/execucoes"
          class="<% if (typeof currentPage !== 'undefined' && currentPage === 'execucoes') { %>active<% } %>"
          ><i data-lucide="scroll-text" class="w-4 h-4"></i> Execuções</a
        >
      </li>
    </ul>
  </div>

  <div class="navbar-end gap-2">
    <form method="POST" action="/logout">
      <button type="submit" class="btn btn-sm btn-ghost">
        <i data-lucide="log-out" class="w-4 h-4"></i> Sair
      </button>
    </form>
    <!-- Mobile dropdown -->
    <div class="dropdown dropdown-end lg:hidden">
      <div tabindex="0" role="button" class="btn btn-ghost btn-sm">
        <i data-lucide="menu" class="w-5 h-5"></i>
      </div>
      <ul
        tabindex="0"
        class="dropdown-content menu menu-sm bg-base-100 rounded-box z-[1] mt-3 w-52 p-2 shadow"
      >
        <li>
          <a href="/"
            ><i data-lucide="layout-dashboard" class="w-4 h-4"></i> Dashboard</a
          >
        </li>
        <li>
          <a href="/tarefas"
            ><i data-lucide="clipboard-list" class="w-4 h-4"></i> Tarefas</a
          >
        </li>
        <li>
          <a href="/execucoes"
            ><i data-lucide="scroll-text" class="w-4 h-4"></i> Execuções</a
          >
        </li>
        <li class="mt-1 border-t border-base-300 pt-1">
          <form method="POST" action="/logout">
            <button type="submit" class="w-full text-left">Sair</button>
          </form>
        </li>
      </ul>
    </div>
  </div>
</div>
