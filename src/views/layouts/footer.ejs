  </main>

  <footer class="footer footer-center p-4 bg-base-200 text-base-content">
    <aside>
      <p class="text-xs opacity-50 flex items-center gap-1"><i data-lucide="corporate" class="w-3 h-3"></i> Fatia Rápida v2 — Raspberry Pi Edition</p>
    </aside>
  </footer>

  <script>
    // Initialise Lucide icons (initial load + after every HTMX swap)
    function initIcons() {
      if (typeof lucide !== 'undefined') lucide.createIcons();
    }

    // Dia-da-semana chip toggle
    function initDaysToggle(root) {
      var scope = root || document;
      scope.querySelectorAll('.dia-check').forEach(function(label) {
        var cb = label.querySelector('input[type="checkbox"]');
        if (!cb) return;
        // Set initial visual state
        if (cb.checked) label.classList.add('selected');
        else label.classList.remove('selected');
        // Avoid double-binding
        if (label.dataset.daysInit) return;
        label.dataset.daysInit = '1';
        label.addEventListener('click', function() {
          // Timeout 0 so the browser toggles cb.checked before we read it
          setTimeout(function() {
            if (cb.checked) label.classList.add('selected');
            else label.classList.remove('selected');
          }, 0);
        });
      });
    }

    function initAll(root) {
      initIcons();
      initDaysToggle(root);
    }

    document.addEventListener('DOMContentLoaded', function() { initAll(); });
    document.body.addEventListener('htmx:afterSwap', function() { initAll(); });
    document.body.addEventListener('htmx:afterSettle', function() { initAll(); });

    // Auto-dismiss toasts
    document.body.addEventListener('htmx:afterSwap', function() {
      document.querySelectorAll('#toast-container .alert').forEach(function(t) {
        setTimeout(function() { t.style.opacity = '0'; t.style.transition = 'opacity 0.5s'; }, 3000);
        setTimeout(function() { t.remove(); }, 3500);
      });
    });

    // Horários: event delegation — sem onclick inline (bloqueado por CSP)
    document.body.addEventListener('click', function(e) {
      // Botão "+ Horário"
      var addBtn = e.target.closest('.add-horario');
      if (addBtn) {
        var container = addBtn.closest('.form-control').querySelector('.horarios-list');
        var div = document.createElement('div');
        div.className = 'flex items-center gap-2 mt-2 horario-input-group';
        var input = document.createElement('input');
        input.type = 'time';
        input.name = 'horarios';
        input.required = true;
        input.className = 'input input-bordered input-sm w-36';
        var removeBtn = document.createElement('button');
        removeBtn.type = 'button';
        removeBtn.className = 'btn btn-square btn-xs btn-error btn-outline remove-horario';
        removeBtn.innerHTML = '<i data-lucide="x" class="w-3 h-3"></i>';
        div.appendChild(input);
        div.appendChild(removeBtn);
        container.appendChild(div);
        initAll(div);
        return;
      }

      // Botão "×" remover horário
      var removeBtn = e.target.closest('.remove-horario');
      if (removeBtn) {
        var group = removeBtn.closest('.horario-input-group');
        if (group) group.remove();
        return;
      }
    });

    // Script selector toggle em tarefa-form
    (function() {
      var scriptSelect = document.getElementById('scriptId');
      var comandoSection = document.getElementById('comando-section');
      if (!scriptSelect || !comandoSection) return;
      function toggleComando() {
        var hasScript = scriptSelect.value !== '';
        comandoSection.style.opacity = hasScript ? '0.4' : '1';
        comandoSection.querySelectorAll('textarea, input').forEach(function(el) {
          el.disabled = hasScript;
        });
        var label = comandoSection.querySelector('.label-text');
        if (label) {
          label.textContent = hasScript
            ? 'Comando / Payload (ignorado — script vinculado)'
            : 'Comando / Payload';
        }
      }
      toggleComando();
      scriptSelect.addEventListener('change', toggleComando);
    })();
  </script>
</body>
</html>
