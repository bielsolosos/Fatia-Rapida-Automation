      </main>

      <footer class="footer p-4 bg-base-200 text-base-content flex items-center justify-between border-t border-base-300">
        <aside>
          <p class="text-xs opacity-50 flex items-center gap-1">
            <i data-lucide="pizza" class="w-3 h-3"></i> Fatia Rápida Automation
          </p>
        </aside>
        <a href="/about" class="btn btn-ghost btn-xs gap-1 opacity-50 hover:opacity-100 transition-opacity">
          <i data-lucide="info" class="w-3 h-3"></i>
          <span class="text-xs">Sobre</span>
        </a>
      </footer>
    </div> <!-- end drawer-content -->

    <div class="drawer-side z-40">
      <label for="main-drawer" class="drawer-overlay" aria-label="fechar menu"></label>
      <% if (typeof isAuthenticated !== 'undefined' && isAuthenticated) { %>
        <%- include('../partials/navbar') %>
      <% } %>
    </div>
  </div> <!-- end drawer -->

  <script>
    // Initialise Lucide icons
    function initIcons() {
      if (typeof lucide !== 'undefined') lucide.createIcons();
    }

    // Toggle Drawer logic (Mobile vs Desktop)
    function initDrawerToggle() {
      const btn = document.getElementById('toggle-drawer');
      const checkbox = document.getElementById('main-drawer');
      const container = document.getElementById('drawer-container');
      
      if (!btn || !checkbox || !container) return;
      
      // Evita adicionar múltiplos listeners se o HTMX carregar a página de novo
      if (btn.dataset.bound === 'true') return;
      btn.dataset.bound = 'true';

      btn.addEventListener('click', function(e) {
        e.preventDefault();
        e.stopPropagation();

        if (window.innerWidth >= 1024) {
          // No DESKTOP, alternamos a classe lg:drawer-open que o DaisyUI usa para o estado fixo
          const isOpen = container.classList.toggle('lg:drawer-open');
          localStorage.setItem('drawer-pinned', isOpen);
          // Força o checkbox a ficar falso para não sobrepor nada
          checkbox.checked = false;
        } else {
          // No MOBILE, o comportamento padrão do DaisyUI é via checkbox
          checkbox.checked = !checkbox.checked;
        }
      });
    }

    // Dia-da-semana chip toggle
    function initDaysToggle(root) {
      var scope = root || document;
      scope.querySelectorAll('.dia-check').forEach(function(label) {
        var cb = label.querySelector('input[type="checkbox"]');
        if (!cb || label.dataset.daysInit) return;
        label.dataset.daysInit = '1';
        if (cb.checked) label.classList.add('selected');
        label.addEventListener('click', function() {
          setTimeout(function() {
            if (cb.checked) label.classList.add('selected');
            else label.classList.remove('selected');
          }, 0);
        });
      });
    }

    function initAll(root) {
      initIcons();
      initDaysToggle(root);
      initDrawerToggle();
    }

    document.addEventListener('DOMContentLoaded', function() { initAll(); });
    document.body.addEventListener('htmx:afterSwap', function() { initAll(); });
    document.body.addEventListener('htmx:afterSettle', function() { initAll(); });

    // Auto-dismiss toasts
    document.body.addEventListener('htmx:afterSwap', function() {
      document.querySelectorAll('#toast-container .alert').forEach(function(t) {
        setTimeout(function() { t.style.opacity = '0'; t.style.transition = 'opacity 0.5s'; }, 3000);
        setTimeout(function() { t.remove(); }, 3500);
      });
    });

    // Horários: event delegation
    document.body.addEventListener('click', function(e) {
      var addBtn = e.target.closest('.add-horario');
      if (addBtn) {
        var container = addBtn.closest('.form-control').querySelector('.horarios-list');
        var div = document.createElement('div');
        div.className = 'flex items-center gap-2 mt-2 horario-input-group';
        div.innerHTML = '<input type="time" name="horarios" required class="input input-bordered input-sm w-36">' +
                        '<button type="button" class="btn btn-square btn-xs btn-error btn-outline remove-horario"><i data-lucide="x" class="w-3 h-3"></i></button>';
        container.appendChild(div);
        initAll(div);
        return;
      }
      var removeBtn = e.target.closest('.remove-horario');
      if (removeBtn) {
        var group = removeBtn.closest('.horario-input-group');
        if (group) group.remove();
        return;
      }
    });

    // Close drawer after HTMX navigation on mobile
    document.body.addEventListener('htmx:beforeSwap', function() {
      const drawerToggle = document.getElementById('main-drawer');
      if (drawerToggle && drawerToggle.checked && window.innerWidth < 1024) {
        drawerToggle.checked = false;
      }
    });
  </script>
</body>
</html>
