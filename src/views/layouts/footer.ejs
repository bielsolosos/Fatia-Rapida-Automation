  </main>

  <footer class="footer footer-center p-4 bg-base-200 text-base-content mt-8">
    <aside>
      <p class="text-xs opacity-50 flex items-center gap-1"><i data-lucide="pizza" class="w-3 h-3"></i> Fatia Rápida v2 — Raspberry Pi Edition</p>
    </aside>
  </footer>

  <script>
    // Initialise Lucide icons (initial load + after every HTMX swap)
    function initIcons() {
      if (typeof lucide !== 'undefined') lucide.createIcons();
    }

    // Dia-da-semana chip toggle
    function initDaysToggle(root) {
      var scope = root || document;
      scope.querySelectorAll('.dia-check').forEach(function(label) {
        var cb = label.querySelector('input[type="checkbox"]');
        if (!cb) return;
        // Set initial visual state
        if (cb.checked) label.classList.add('selected');
        else label.classList.remove('selected');
        // Avoid double-binding
        if (label.dataset.daysInit) return;
        label.dataset.daysInit = '1';
        label.addEventListener('click', function() {
          // Timeout 0 so the browser toggles cb.checked before we read it
          setTimeout(function() {
            if (cb.checked) label.classList.add('selected');
            else label.classList.remove('selected');
          }, 0);
        });
      });
    }

    function initAll(root) {
      initIcons();
      initDaysToggle(root);
    }

    document.addEventListener('DOMContentLoaded', function() { initAll(); });
    document.body.addEventListener('htmx:afterSwap', function() { initAll(); });
    document.body.addEventListener('htmx:afterSettle', function() { initAll(); });

    // Auto-dismiss toasts
    document.body.addEventListener('htmx:afterSwap', function() {
      document.querySelectorAll('#toast-container .alert').forEach(function(t) {
        setTimeout(function() { t.style.opacity = '0'; t.style.transition = 'opacity 0.5s'; }, 3000);
        setTimeout(function() { t.remove(); }, 3500);
      });
    });

    // Add horário input dynamically
    function addHorario(agIndex) {
      var container = document.getElementById('horarios-' + agIndex);
      var div = document.createElement('div');
      div.className = 'flex items-center gap-2 mt-2';
      div.innerHTML = '<input type="time" name="agendamentos[' + agIndex + '][horarios]" required class="input input-bordered input-sm w-36">'
        + '<button type="button" class="btn btn-square btn-xs btn-error" onclick="this.parentElement.remove()"><i data-lucide="x" class="w-3 h-3"></i></button>';
      container.appendChild(div);
      initAll();
    }

    // Add agendamento group dynamically
    var agendamentoIndex = document.querySelectorAll('.agendamento-group').length || 1;
    function addAgendamento() {
      fetch('/tarefas/partial/agendamento-fields?index=' + agendamentoIndex)
        .then(function(r) { return r.text(); })
        .then(function(html) {
          document.getElementById('agendamentos-container').insertAdjacentHTML('beforeend', html);
          agendamentoIndex++;
          initAll();
        });
    }
  </script>
</body>
</html>
