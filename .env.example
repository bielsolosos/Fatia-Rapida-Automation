# ── Server ──
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# ── Database ──
DATABASE_URL="file:./data/fatia.db"

# ── Admin (single-user) ──
# Gere o hash com: npm run hash-password
ADMIN_EMAIL=admin@fatia.local
ADMIN_PASSWORD_HASH=$2b$10$exemplo...

# ── Session ──
SESSION_SECRET=troque-por-uma-string-aleatoria-de-32-chars

# ── Scheduler ──
ENABLE_SCHEDULER=true
TZ=America/Sao_Paulo

# ── Log ──
LOG_LEVEL=info
