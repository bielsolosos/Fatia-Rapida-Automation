{
  "name": "fatia-rapida",
  "version": "2.0.0",
  "description": "Automação de tarefas com agendamento — Fastify + HTMX + EJS",
  "author": "bielsolosos",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc && npm run build:copy",
    "build:copy": "copyfiles -u 1 \"src/views/**/*\" dist && copyfiles -u 1 \"public/**/*\" dist/../",
    "start": "node dist/server.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "hash-password": "tsx scripts/hash-password.ts",
    "seed": "tsx scripts/seed.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.1",
    "@fastify/formbody": "^8.0.1",
    "@fastify/helmet": "^12.0.1",
    "@fastify/session": "^11.0.1",
    "@fastify/static": "^8.0.3",
    "@fastify/view": "^10.0.1",
    "@prisma/client": "^5.22.0",
    "axios": "^1.7.9",
    "bcrypt": "^5.1.1",
    "dotenv": "^16.4.7",
    "ejs": "^3.1.10",
    "fastify": "^5.1.0",
    "fastify-plugin": "^5.0.1",
    "node-cron": "^3.0.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/ejs": "^3.1.5",
    "@types/node": "^22.10.2",
    "@types/node-cron": "^3.0.11",
    "copyfiles": "^2.4.1",
    "pino-pretty": "^13.0.0",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
